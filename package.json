{
  "name": "temuniaga",
  "private": true,
  "packageManager": "pnpm@10.8.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @temuniaga/database run generate",
    "db:migrate": "pnpm --filter @temuniaga/database run migrate",
    "db:seed": "pnpm --filter @temuniaga/database run seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.0"
  }
}
