# Set to "true" once you're ready to scan the QR code and connect a real WA number.
WA_ENABLED=false
WA_AUTH_DIR=./wa-auth
WA_MAX_AUDIO_BYTES=5242880

# apps/api base URL -- whatsapp-worker never touches the database directly,
# it calls apps/api for harga/pasokan/simpanan (plan.md §16.4 rule 1).
API_BASE_URL=http://localhost:3501

# Gemini (get a free key at https://aistudio.google.com/apikey).
# Without it: keyword commands (HARGA/LAPOR/STATUS) still work, but there's
# no natural-language fallback and voice replies use the espeak-ng fallback
# (robotic voice) instead of Gemini TTS.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# Local binaries (override only if not on PATH).
WHISPER_BIN=whisper
ESPEAK_BIN=espeak-ng

PORT=4001
