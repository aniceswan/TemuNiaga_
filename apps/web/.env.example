# apps/web never talks to the database directly -- every page and the
# login route handler call apps/api over HTTP. This is the only setting
# that changes between deployment modes:
#   - Mode 1 (full local):            http://localhost:3501
#   - Mode 2 (frontend deployed):     https://<your-tunnel-or-hosted-api>
# See README.md "Mode Deployment" for the full walkthrough.
API_BASE_URL=http://localhost:3501

# Nomor WA bot (yang scan QR di apps/whatsapp-worker), format 62xxxxxxxxxx
# tanpa "+"/"0" di depan -- dipakai untuk link wa.me di dashboard registrasi WA.
NEXT_PUBLIC_WA_BOT_PHONE=6289563154904
